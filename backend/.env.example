# Copy to .env and fill in what you use.

# ---- AI provider ------------------------------------------------------
# "auto" picks the first configured of: anthropic > gemini > groq > ollama.
# Or set explicitly: anthropic | gemini | groq | ollama | none
AI_PROVIDER=auto

# Option A (FREE, recommended): Google Gemini — key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Option B (FREE): Groq — key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option C (FREE, local/offline): Ollama — install from https://ollama.com
# then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Option D (paid): Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-fable-5
CLAUDE_FALLBACK_MODEL=claude-opus-4-8

# ---- Other ------------------------------------------------------------
DATABASE_URL=sqlite:///./resume_intel.db
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
CORS_ORIGINS=http://localhost:3000
